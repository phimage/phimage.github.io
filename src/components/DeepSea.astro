---
/*
  DeepSea — ambient background.
  Bioluminescent drift + surface light-shafts that fade with depth +
  a depth veil that darkens the water the deeper you scroll.
  Fixed, behind all content, pointer-events:none. Calm/static under reduced-motion.
*/
---
<canvas id="deepsea" aria-hidden="true"></canvas>

<style>
  #deepsea {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
    display: block;
  }
</style>

<script>
  const canvas = document.getElementById("deepsea");
  if (canvas && canvas.getContext) {
    const ctx = canvas.getContext("2d");
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let W = 0, H = 0, dpr = 1;
    let scrollY = window.scrollY || 0;
    let raf = 0, running = false;
    const PAR = reduce ? 0 : 0.045; // parallax descent factor

    // pre-rendered bioluminescent glow sprite (cheap to stamp many times)
    const SS = 64;
    const sprite = document.createElement("canvas");
    sprite.width = sprite.height = SS;
    const sctx = sprite.getContext("2d");
    const grad = sctx.createRadialGradient(SS / 2, SS / 2, 0, SS / 2, SS / 2, SS / 2);
    grad.addColorStop(0, "rgba(150,250,232,0.95)");
    grad.addColorStop(0.25, "rgba(69,230,207,0.55)");
    grad.addColorStop(1, "rgba(69,230,207,0)");
    sctx.fillStyle = grad;
    sctx.fillRect(0, 0, SS, SS);

    let particles = [];
    function makeParticles() {
      const count = Math.round(Math.min(90, Math.max(34, (W * H) / 22000)));
      particles = [];
      for (let i = 0; i < count; i++) {
        particles.push({
          x: Math.random() * W,
          y: Math.random() * H,
          z: 0.35 + Math.random() * 1.0,        // depth → size + parallax
          a: 0.1 + Math.random() * 0.45,         // base alpha
          vy: 0.05 + Math.random() * 0.16,       // slow marine-snow drift
          vx: (Math.random() - 0.5) * 0.1,
          ph: Math.random() * Math.PI * 2,       // pulse phase
          pf: 0.4 + Math.random() * 0.9,         // pulse speed
          bright: Math.random() < 0.18,          // a few brighter blooms
        });
      }
    }

    function resize() {
      W = window.innerWidth;
      H = window.innerHeight;
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = W * dpr;
      canvas.height = H * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      makeParticles();
      if (reduce) draw(0);
    }

    function depth() {
      const max = document.documentElement.scrollHeight - window.innerHeight;
      return max > 0 ? Math.min(1, Math.max(0, scrollY / max)) : 0;
    }

    function draw(t) {
      ctx.clearRect(0, 0, W, H);
      const dp = depth();

      // surface light-shafts — fade out as you descend
      const rayFade = Math.max(0, 1 - dp * 1.7);
      if (rayFade > 0.01) {
        ctx.globalCompositeOperation = "lighter";
        const rays = [
          { x: 0.22, w: 0.085 },
          { x: 0.5, w: 0.06 },
          { x: 0.8, w: 0.1 },
        ];
        for (const r of rays) {
          const sway = reduce ? 0 : Math.sin(t * 0.0002 + r.x * 6) * W * 0.012;
          const cx = r.x * W + sway;
          const w = r.w * W;
          const g = ctx.createLinearGradient(cx, -H * 0.1, cx, H * 0.75);
          g.addColorStop(0, "rgba(86,224,208," + 0.07 * rayFade + ")");
          g.addColorStop(1, "rgba(86,224,208,0)");
          ctx.fillStyle = g;
          ctx.beginPath();
          ctx.moveTo(cx - w * 0.3, 0);
          ctx.lineTo(cx + w * 0.3, 0);
          ctx.lineTo(cx + w, H * 0.78);
          ctx.lineTo(cx - w, H * 0.78);
          ctx.closePath();
          ctx.fill();
        }
      }

      // depth veil — the deeper you scroll, the darker the water
      ctx.globalCompositeOperation = "source-over";
      if (dp > 0.001) {
        ctx.fillStyle = "rgba(2,5,11," + 0.62 * dp + ")";
        ctx.fillRect(0, 0, W, H);
      }

      // bioluminescent specks, glowing over the dark
      ctx.globalCompositeOperation = "lighter";
      const spanY = H + 80, spanX = W + 80;
      for (const p of particles) {
        if (!reduce) {
          p.y += p.vy * p.z;
          p.x += p.vx;
          p.ph += 0.01 * p.pf;
        }
        let py = p.y - scrollY * PAR * p.z;
        py = (((py % spanY) + spanY) % spanY) - 40;
        const px = (((p.x % spanX) + spanX) % spanX) - 40;
        const pulse = reduce ? 0.85 : 0.6 + 0.4 * Math.sin(p.ph);
        const size = (p.bright ? 11 : 5) * p.z;
        const alpha = p.a * pulse * (p.bright ? 1 : 0.8) * (0.7 + dp * 0.55);
        ctx.globalAlpha = Math.min(0.95, alpha);
        ctx.drawImage(sprite, px - size / 2, py - size / 2, size, size);
      }
      ctx.globalAlpha = 1;
      ctx.globalCompositeOperation = "source-over";
    }

    function loop(t) {
      draw(t);
      raf = requestAnimationFrame(loop);
    }
    function start() {
      if (!running && !reduce) {
        running = true;
        raf = requestAnimationFrame(loop);
      }
    }
    function stop() {
      running = false;
      cancelAnimationFrame(raf);
    }

    window.addEventListener("resize", resize, { passive: true });
    window.addEventListener(
      "scroll",
      () => {
        scrollY = window.scrollY || 0;
        if (reduce) draw(0);
      },
      { passive: true }
    );
    document.addEventListener("visibilitychange", () => {
      if (document.hidden) stop();
      else start();
    });

    resize();
    start();
  }
</script>
