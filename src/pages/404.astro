---
import Base from "../layouts/Base.astro";
---
<Base title="Lost in the deep" current="/">
  <section class="shell" style="padding-top:clamp(4rem,10vw,7rem); text-align:left">
    <p class="eyebrow">Depth unknown</p>
    <h1>This page sank without a trace.</h1>
    <p class="lead-2" style="margin-bottom:1.6rem">
      No light reaches this part of the column. Let&rsquo;s head back toward the surface.
    </p>
    <div class="cta-row">
      <a class="btn" href="/">Back home</a>
      <a class="btn" href="/blog/">Read the writing</a>
    </div>
  </section>
</Base>
